    "{ \"cells\": [{ \"cell_type\": \"markdown\", \"metadata\": {}, \"source\": [\"# M2T2L8 - Operaciones sobre RDD\\nMap, filter, reduceByKey, groupByKey.\"]}, { \"cell_type\": \"code\", \"execution_count\": null, \"metadata\": {}, \"outputs\": [], \"source\": [\"from pyspark import SparkContext\\nsc = SparkContext()\n",
    "rdd = sc.parallelize(['a b a', 'b c'])\\nwords = rdd.flatMap(lambda r: r.split())\\ncounts = words.map(lambda w: (w,1)).reduceByKey(lambda a,b: a+b).collect()\\nprint(counts)\\nsc.stop()\"]}], \"metadata\": {\"kernelspec\": {\"display_name\": \"Python 3\",\"language\": \"python\",\"name\": \"python3\"}, \"language_info\": {\"name\": \"python\"}}, \"nbformat\": 4, \"nbformat_minor\": 5 }\n"
